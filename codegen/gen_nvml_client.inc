      rpc_read(conn, &return_value, sizeof(return_value)) < 0 ||
      rpc_read_end(conn) < 0) {
    return rpc_error();
  }
  return return_value;
}

extern "C" nvmlReturn_t
nvmlDeviceGetNvLinkRemotePciInfo_v2(nvmlDevice_t device, unsigned int link,
                                    nvmlPciInfo_t *pci) {
  if (pci == nullptr) {
    return NVML_ERROR_INVALID_ARGUMENT;
  }
  conn_t *conn = connection_for_device(&device);
  return lupine_rpc_nvmlDeviceGetNvLinkRemotePciInfo_v2(conn, device, link,
                                                        pci);
}
